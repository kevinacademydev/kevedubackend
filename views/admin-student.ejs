<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= student.name %> - 학생 관리</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="student-layout">
    <%- include('partials/admin-sidebar', { activePage: 'student' }) %>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <main class="student-main">
      <div class="student-topbar">
        <button class="hamburger-btn" id="hamburgerBtn">&#9776;</button>
        <h2 class="topbar-title"><%= student.name %></h2>
      </div>

      <div class="student-content" id="adminStudentPage" data-student-id="<%= student.id %>" data-user-role="<%= userRole %>">

        <!-- 학생 정보 -->
        <div class="card" style="margin-bottom:1.5rem;">
          <div class="card-header"><h3>학생 정보</h3></div>
          <div class="card-body">
            <div class="student-info-grid">
              <div><strong>아이디:</strong> <%= student.username %></div>
              <div><strong>이름:</strong> <%= student.name %></div>
              <div><strong>영문이름:</strong> <%= student.name_en || '-' %></div>
              <div><strong>성별:</strong> <%= student.gender || '-' %></div>
              <div><strong>생년월일:</strong> <%= student.birth_date || '-' %></div>
              <div><strong>학년:</strong> <%= student.grade || '-' %></div>
              <div><strong>학교:</strong> <%= student.school || '-' %></div>
              <div><strong>학부모 연락처:</strong> <%= student.parent_phone || '-' %></div>
              <div><strong>이메일:</strong> <%= student.email || '-' %></div>
              <div><strong>가입일:</strong> <%= student.created_at %></div>
            </div>
          </div>
        </div>

        <!-- 수업 목록 -->
        <div class="card" style="margin-bottom:1.5rem;">
          <div class="card-header"><h3>수업 목록</h3></div>
          <div class="card-body">
            <% if (classes.length === 0) { %>
              <p class="empty-message">등록된 수업이 없습니다.</p>
            <% } else { %>
              <% classes.forEach(cls => { %>
                <a href="/admin/class/<%= cls.id %>" class="class-card <%= cls.status === 'dropped' ? 'class-inactive' : '' %>" style="display:block;margin-bottom:0.5rem;">
                  <div class="class-card-info">
                    <strong><%= cls.name %></strong>
                    <span class="badge"><%= cls.type === 'regular' ? '정규' : cls.type === 'team' ? '그룹' : '개인' %></span>
                    <span class="badge"><%= cls.status === 'active' ? '등록' : '해제' %></span>
                  </div>
                </a>
              <% }) %>
            <% } %>
          </div>
        </div>

        <div class="dashboard-grid">
          <!-- 피드백 -->
          <div>
            <div class="card">
              <div class="card-header"><h3>피드백</h3></div>
              <div class="card-body">
                <div class="form-group" style="margin-bottom:1rem;">
                  <textarea id="feedbackContent" rows="3" placeholder="피드백 내용을 입력하세요..." style="width:100%;padding:0.65rem;border:1.5px solid var(--gray-300);border-radius:var(--radius);font-size:0.9rem;resize:vertical;"></textarea>
                  <button class="btn btn-sm btn-primary" id="btnAddFeedback" style="margin-top:0.5rem;">피드백 작성</button>
                </div>
                <div id="feedbackList">
                  <% if (feedbacks.length === 0) { %>
                    <p class="empty-message">작성된 피드백이 없습니다.</p>
                  <% } else { %>
                    <% feedbacks.forEach(fb => { %>
                      <div class="file-item" style="flex-direction:column;align-items:flex-start;gap:0.25rem;">
                        <div style="display:flex;justify-content:space-between;width:100%;align-items:center;">
                          <span class="file-date"><strong><%= fb.author_name %></strong> | <%= fb.created_at %></span>
                          <button class="btn btn-sm btn-outline btn-delete-feedback" data-id="<%= fb.id %>">삭제</button>
                        </div>
                        <p style="font-size:0.9rem;white-space:pre-wrap;"><%= fb.content %></p>
                      </div>
                    <% }) %>
                  <% } %>
                </div>
              </div>
            </div>
          </div>

          <!-- 상담기록 (원장만) -->
          <div>
            <% if (userRole === 'admin' || userRole === 'subadmin') { %>
            <div class="card">
              <div class="card-header"><h3>상담기록</h3></div>
              <div class="card-body">
                <div class="form-group" style="margin-bottom:1rem;">
                  <textarea id="consultationContent" rows="3" placeholder="상담기록 내용을 입력하세요..." style="width:100%;padding:0.65rem;border:1.5px solid var(--gray-300);border-radius:var(--radius);font-size:0.9rem;resize:vertical;"></textarea>
                  <button class="btn btn-sm btn-primary" id="btnAddConsultation" style="margin-top:0.5rem;">상담기록 작성</button>
                </div>
                <div id="consultationList">
                  <% if (consultations.length === 0) { %>
                    <p class="empty-message">작성된 상담기록이 없습니다.</p>
                  <% } else { %>
                    <% consultations.forEach(con => { %>
                      <div class="file-item" style="flex-direction:column;align-items:flex-start;gap:0.25rem;">
                        <div style="display:flex;justify-content:space-between;width:100%;align-items:center;">
                          <span class="file-date"><strong><%= con.author_name %></strong> | <%= con.created_at %></span>
                          <button class="btn btn-sm btn-outline btn-delete-consultation" data-id="<%= con.id %>">삭제</button>
                        </div>
                        <p style="font-size:0.9rem;white-space:pre-wrap;"><%= con.content %></p>
                      </div>
                    <% }) %>
                  <% } %>
                </div>
              </div>
            </div>
            <% } %>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script src="/js/app.js"></script>
</body>
</html>
