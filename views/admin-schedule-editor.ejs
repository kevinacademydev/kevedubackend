<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>시간표 편집 - 케빈아카데미</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="student-layout">
    <%- include('partials/admin-sidebar', { activePage: 'schedule-pages' }) %>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <main class="student-main">
      <div class="student-topbar">
        <button class="hamburger-btn" id="hamburgerBtn">&#9776;</button>
        <h2 class="topbar-title">시간표 편집</h2>
        <div style="margin-left:auto;display:flex;gap:0.5rem;">
          <% if (userRole !== 'admin' && userRole !== 'subadmin') { %>
            <button class="btn btn-sm btn-warning" id="seRequestReviewBtn">발행 신청하기</button>
          <% } %>
          <button class="btn btn-sm btn-outline" id="sePreviewBtn">미리보기</button>
          <button class="btn btn-sm btn-primary" id="seSaveBtn">저장</button>
        </div>
      </div>

      <div class="student-content" id="scheduleEditorPage"
           data-page-id="<%= pageId || '' %>"
           data-user-role="<%= userRole %>">

        <div id="seSaveMsg" class="alert alert-success" style="display:none;"></div>

        <!-- Owner info (admin editing teacher's page) -->
        <div id="seOwnerInfo" class="se-owner-info" style="display:none;"></div>

        <!-- 1. Settings -->
        <div class="se-section">
          <button class="se-section-toggle active" data-target="seSettings">
            <span>기본 설정</span>
            <span class="se-arrow">&#9660;</span>
          </button>
          <div class="se-section-body open" id="seSettings">
            <div class="form-row">
              <div class="form-group">
                <label>제목</label>
                <input type="text" id="seTitle" placeholder="예: 2026 Summer Bootcamp">
              </div>
              <div class="form-group">
                <label>Slug (URL)</label>
                <input type="text" id="seSlug" placeholder="summer-bootcamp-2026">
                <small style="color:var(--gray-500);">공개 URL: /p/<span id="seSlugPreview">-</span></small>
              </div>
            </div>
            <div class="form-group" style="max-width:200px;">
              <label>상태</label>
              <select id="seStatus">
                <option value="draft">초안 (Draft)</option>
                <% if (userRole === 'admin' || userRole === 'subadmin') { %>
                  <option value="private">비공개 (Private)</option>
                  <option value="published">공개 (Published)</option>
                <% } else { %>
                  <option value="pending">심사 중 (Pending)</option>
                <% } %>
              </select>
            </div>
          </div>
        </div>

        <!-- 2. Header/Hero -->
        <div class="se-section">
          <button class="se-section-toggle" data-target="seHeader">
            <span>헤더 / 히어로</span>
            <span class="se-arrow">&#9660;</span>
          </button>
          <div class="se-section-body" id="seHeader">
            <div class="form-group">
              <label>프로그램 제목</label>
              <input type="text" id="seHeroProgramTitle" placeholder="2026 Summer Math Bootcamp">
            </div>
            <div class="form-group">
              <label>부제</label>
              <input type="text" id="seHeroSubtitle" placeholder="Intensive 8-Week Program">
            </div>
            <div class="form-group">
              <label>설명</label>
              <textarea id="seHeroDesc" rows="3" placeholder="프로그램 설명..."></textarea>
            </div>

            <div class="se-list-section">
              <label>프로그램 카드</label>
              <div id="seHeroCards"></div>
              <button class="btn btn-sm btn-outline" id="seAddCard">+ 카드 추가</button>
            </div>

            <div class="se-list-section">
              <label>하이라이트</label>
              <div id="seHeroHighlights"></div>
              <button class="btn btn-sm btn-outline" id="seAddHighlight">+ 하이라이트 추가</button>
            </div>

            <div class="form-group" style="margin-top:1rem;">
              <label>수업 신청 URL</label>
              <input type="text" id="seClassAppUrl" placeholder="https://...">
              <small style="color:var(--gray-500);">입력 시 공개 페이지에 "수업 신청하기" 버튼이 표시됩니다.</small>
            </div>
          </div>
        </div>

        <!-- 2.5 Subject Registry -->
        <div class="se-section">
          <button class="se-section-toggle" data-target="seSubjectRegistry">
            <span>과목 관리 (Subjects)</span>
            <span class="se-arrow">&#9660;</span>
          </button>
          <div class="se-section-body" id="seSubjectRegistry">
            <p style="font-size:0.82rem;color:var(--gray-500);margin-bottom:0.75rem;">분반에서 선택할 과목을 등록하세요. 과목별로 실라버스가 자동 연결됩니다.</p>
            <div id="seSubjectList" class="se-subject-list"></div>
            <button class="btn btn-sm btn-outline" id="seAddSubjectReg" style="margin-top:0.5rem;">+ 과목 추가</button>
          </div>
        </div>

        <!-- 3. Schedule Tables (Multiple) -->
        <div class="se-section">
          <button class="se-section-toggle" data-target="seSchedule">
            <span>시간표 (Schedule)</span>
            <span class="se-arrow">&#9660;</span>
          </button>
          <div class="se-section-body" id="seSchedule">
            <div id="seScheduleList"></div>
            <button class="btn btn-sm btn-outline" id="seAddSchedule" style="margin-top:0.5rem;">+ 시간표 추가하기</button>
          </div>
        </div>

        <!-- 4. Syllabus -->
        <div class="se-section">
          <button class="se-section-toggle" data-target="seSyllabus">
            <span>교과 과정 (Syllabus)</span>
            <span class="se-arrow">&#9660;</span>
          </button>
          <div class="se-section-body" id="seSyllabus">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.75rem;">
              <div id="seSyllabusTabBar" class="se-syllabus-tabs" style="margin-bottom:0;"></div>
              <div class="se-lang-toggle" style="position:static;flex-shrink:0;">
                <button class="se-lang-btn active" data-lang="ko">KOR</button>
                <button class="se-lang-btn" data-lang="en">ENG</button>
              </div>
            </div>
            <button class="btn btn-sm btn-outline" id="seAddSubject" style="margin-bottom:1rem;">+ 과목 추가</button>
            <div id="seSyllabusPanel"></div>
          </div>
        </div>

        <!-- 5. Theme -->
        <div class="se-section">
          <button class="se-section-toggle" data-target="seTheme">
            <span>테마 (Theme)</span>
            <span class="se-arrow">&#9660;</span>
          </button>
          <div class="se-section-body" id="seTheme">
            <div class="form-row">
              <div class="form-group">
                <label>히어로 배경색</label>
                <div style="display:flex;gap:0.5rem;align-items:center;">
                  <input type="color" id="seThemeHeroBg" value="#133327" style="height:40px;flex-shrink:0;">
                  <button type="button" class="btn btn-sm btn-outline" id="seThemeKevinPreset" style="white-space:nowrap;">케빈아카데미 테마 컬러 사용하기</button>
                </div>
              </div>
              <div class="form-group">
                <label>강조색</label>
                <input type="color" id="seThemeAccent" value="#ffffff" style="height:40px;">
              </div>
            </div>
          </div>
        </div>

        <!-- 6. 강사 프로필 -->
        <div class="se-section">
          <button class="se-section-toggle" data-target="seProfile">
            <span>강사 프로필</span>
            <span class="se-arrow">&#9660;</span>
          </button>
          <div class="se-section-body" id="seProfile">
            <div id="seProfileImagePreview" class="se-profile-preview"></div>
            <input type="file" id="seProfileImageInput" accept="image/*" style="display:none;">
            <div style="display:flex;gap:0.5rem;">
              <button class="btn btn-sm btn-outline" id="seUploadProfileImage">이미지 업로드</button>
              <button class="btn btn-sm btn-danger" id="seDeleteProfileImage" style="display:none;">삭제</button>
            </div>
            <small style="color:var(--gray-500);">공개 시간표 페이지 하단에 표시됩니다.</small>
          </div>
        </div>

      </div>
    </main>
  </div>

  <!-- Section popup (dynamic content filled by JS) -->
  <div id="seBlockPopup" class="se-cell-popup" style="display:none;">
    <div class="se-cell-popup-inner"></div>
  </div>

  <script>window.__SEC='<%= sectionPath %>';window.__BASE='<%= basePath %>'</script>
  <script src="/js/app.js"></script>
</body>
</html>
