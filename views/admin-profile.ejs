<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>프로필 편집 - 케빈아카데미</title>
  <link rel="icon" type="image/png" href="/images/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="student-layout">
    <%- include('partials/admin-sidebar', { activePage: 'profile' }) %>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <main class="student-main">
      <div class="student-topbar">
        <button class="hamburger-btn" id="hamburgerBtn">&#9776;</button>
        <h2 class="topbar-title">프로필 편집</h2>
      </div>

      <div class="student-content">
        <div class="card" style="max-width:500px;">
          <div class="card-header">
            <h3>내 정보</h3>
            <span class="badge"><%= profile.role === 'admin' ? '원장' : profile.role === 'subadmin' ? '부원장' : '강사' %></span>
          </div>
          <div class="card-body">
            <% if (message) { %>
              <div class="alert alert-success" style="margin-bottom:1rem;padding:0.75rem;background:#d4edda;border:1px solid #c3e6cb;border-radius:var(--radius);color:#155724;font-size:0.9rem;"><%= message %></div>
            <% } %>
            <% if (error) { %>
              <div class="alert alert-danger" style="margin-bottom:1rem;padding:0.75rem;background:#f8d7da;border:1px solid #f5c6cb;border-radius:var(--radius);color:#721c24;font-size:0.9rem;"><%= error %></div>
            <% } %>

            <form method="POST" action="<%= sectionPath %>/profile">
              <div class="form-group" style="margin-bottom:1rem;">
                <label>아이디</label>
                <input type="text" name="username" value="<%= profile.username %>" required>
              </div>
              <div class="form-group" style="margin-bottom:1rem;">
                <label>이름</label>
                <input type="text" name="name" value="<%= profile.name %>" required>
              </div>
              <hr style="margin:1.5rem 0;border:none;border-top:1px solid var(--gray-200);">
              <p style="font-size:0.85rem;color:var(--gray-500);margin-bottom:1rem;">비밀번호를 변경하려면 아래 항목을 입력하세요.</p>
              <div class="form-group" style="margin-bottom:1rem;">
                <label>현재 비밀번호</label>
                <input type="password" name="current_password" placeholder="현재 비밀번호">
              </div>
              <div class="form-group" style="margin-bottom:1.5rem;">
                <label>새 비밀번호</label>
                <input type="password" name="new_password" placeholder="새 비밀번호">
              </div>
              <button type="submit" class="btn btn-primary" style="width:100%;">저장</button>
            </form>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script>window.__SEC='<%= sectionPath %>';window.__BASE='<%= basePath %>'</script>
  <script src="/js/app.js"></script>
</body>
</html>
