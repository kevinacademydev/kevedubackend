<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>비밀번호 찾기 - 케빈아카데미</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .step { display: none; }
    .step.active { display: block; }
    .step-indicator {
      display: flex;
      justify-content: center;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
    }
    .step-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: #e0e0e0;
      transition: background 0.3s;
    }
    .step-dot.active { background: #133327; }
    .step-dot.done { background: #16a34a; }
    .method-group {
      display: flex;
      gap: 0.75rem;
      margin-bottom: 1rem;
    }
    .method-btn {
      flex: 1;
      padding: 0.75rem;
      border: 1.5px solid #e0e0e0;
      border-radius: 10px;
      background: #fff;
      cursor: pointer;
      font-size: 0.9rem;
      font-weight: 500;
      color: #555;
      transition: all 0.2s;
      text-align: center;
    }
    .method-btn:hover { border-color: #999; }
    .method-btn.selected {
      border-color: #133327;
      background: #eef5f1;
      color: #133327;
      font-weight: 600;
    }
    .code-input {
      font-size: 1.3rem;
      letter-spacing: 6px;
      text-align: center;
      font-weight: 600;
    }
    .timer {
      text-align: center;
      font-size: 0.85rem;
      color: #e74c3c;
      font-weight: 600;
      margin-top: 0.5rem;
    }
    .msg {
      margin-top: 0.75rem;
      padding: 0.6rem 0.8rem;
      border-radius: 8px;
      font-size: 0.85rem;
    }
    .msg.error { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }
    .msg.success { background: #f0fdf4; color: #16a34a; border: 1px solid #bbf7d0; }
    .input-row {
      display: flex;
      gap: 0.75rem;
      align-items: flex-end;
    }
    .input-row .form-group { flex: 1; }
    .btn-action {
      padding: 0.75rem 1.25rem;
      border: none;
      border-radius: 10px;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      white-space: nowrap;
      background: #133327;
      color: #fff;
    }
    .btn-action:hover { background: #1a4a36; }
    .btn-action:disabled { background: #999; cursor: not-allowed; }
    .success-icon {
      font-size: 3rem;
      margin-bottom: 1rem;
    }
  </style>
</head>
<body>
  <div class="auth-container">
    <div class="auth-card">
      <div class="auth-header">
        <h1>비밀번호 찾기</h1>
        <p>케빈아카데미 첨삭 관리 시스템</p>
      </div>

      <div class="step-indicator">
        <div class="step-dot active" id="dot1"></div>
        <div class="step-dot" id="dot2"></div>
        <div class="step-dot" id="dot3"></div>
      </div>

      <!-- Step 1: 연락처 입력 -->
      <div class="step active" id="step1">
        <div class="method-group">
          <button type="button" class="method-btn" data-type="phone" onclick="selectType('phone')">연락처 (SMS)</button>
          <button type="button" class="method-btn" data-type="email" onclick="selectType('email')">이메일</button>
        </div>
        <div class="form-group">
          <label id="targetLabel">연락처 또는 이메일</label>
          <input type="text" id="targetInput" placeholder="가입 시 등록한 연락처 또는 이메일">
        </div>
        <button type="button" class="btn btn-primary btn-full" id="btnStep1" onclick="step1Send()">인증번호 발송</button>
        <div id="msg1"></div>
      </div>

      <!-- Step 2: 인증번호 입력 -->
      <div class="step" id="step2">
        <div class="form-group">
          <label>인증번호 6자리</label>
          <input type="text" id="codeInput" class="code-input" maxlength="6" placeholder="000000" inputmode="numeric" pattern="[0-9]*">
        </div>
        <div class="timer" id="timer"></div>
        <div class="input-row" style="margin-top: 1rem;">
          <button type="button" class="btn btn-primary btn-full" onclick="step2Verify()">인증 확인</button>
        </div>
        <button type="button" style="width:100%; margin-top:0.5rem; background:none; border:1px solid #e0e0e0; padding:0.6rem; border-radius:10px; cursor:pointer; color:#666; font-size:0.85rem;" onclick="step1Resend()">인증번호 재발송</button>
        <div id="msg2"></div>
      </div>

      <!-- Step 3: 새 비밀번호 설정 -->
      <div class="step" id="step3">
        <div class="form-group">
          <label for="newPassword">새 비밀번호</label>
          <input type="password" id="newPassword" placeholder="새 비밀번호 (4자 이상)" minlength="4">
        </div>
        <div class="form-group">
          <label for="newPasswordConfirm">비밀번호 확인</label>
          <input type="password" id="newPasswordConfirm" placeholder="비밀번호 확인">
        </div>
        <button type="button" class="btn btn-primary btn-full" onclick="step3Reset()">비밀번호 변경</button>
        <div id="msg3"></div>
      </div>

      <!-- 완료 -->
      <div class="step" id="stepDone">
        <div style="text-align: center; padding: 1.5rem 0;">
          <div class="success-icon">&#10003;</div>
          <p style="font-size: 1.1rem; font-weight: 600; color: #133327; margin-bottom: 0.5rem;">비밀번호가 변경되었습니다</p>
          <p style="font-size: 0.85rem; color: #888;">새 비밀번호로 로그인해주세요.</p>
        </div>
        <a href="/management" class="btn btn-primary btn-full" style="text-decoration: none; text-align: center; display: block;">로그인하기</a>
      </div>

      <div class="auth-footer">
        <a href="/management">로그인으로 돌아가기</a>
      </div>
    </div>
  </div>

  <script>
    let targetType = null;
    let target = '';
    let resetToken = '';
    let timerInterval = null;
    let timerSeconds = 0;

    function selectType(type) {
      targetType = type;
      document.querySelectorAll('.method-btn').forEach(btn => {
        btn.classList.toggle('selected', btn.dataset.type === type);
      });
      const input = document.getElementById('targetInput');
      const label = document.getElementById('targetLabel');
      if (type === 'phone') {
        label.textContent = '학부모 연락처';
        input.placeholder = '010-1234-5678';
        input.type = 'tel';
      } else {
        label.textContent = '이메일';
        input.placeholder = 'example@email.com';
        input.type = 'email';
      }
      input.focus();
    }

    function showStep(num) {
      document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
      document.getElementById(num === 'done' ? 'stepDone' : `step${num}`).classList.add('active');
      for (let i = 1; i <= 3; i++) {
        const dot = document.getElementById(`dot${i}`);
        dot.className = 'step-dot';
        if (num === 'done' || i < num) dot.classList.add('done');
        else if (i == num) dot.classList.add('active');
      }
    }

    function showMsg(stepNum, message, type) {
      const el = document.getElementById(`msg${stepNum}`);
      el.className = 'msg ' + type;
      el.textContent = message;
    }

    async function step1Send() {
      if (!targetType) {
        showMsg(1, '인증 방법을 선택해주세요.', 'error');
        return;
      }
      target = document.getElementById('targetInput').value.trim();
      if (!target) {
        showMsg(1, targetType === 'phone' ? '연락처를 입력해주세요.' : '이메일을 입력해주세요.', 'error');
        return;
      }

      const btn = document.getElementById('btnStep1');
      btn.disabled = true;
      btn.textContent = '발송 중...';

      try {
        const res = await fetch('/management/auth/forgot-password/send-code', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ target, target_type: targetType })
        });
        const data = await res.json();

        if (data.success) {
          showStep(2);
          document.getElementById('codeInput').focus();
          startTimer(300);
        } else {
          showMsg(1, data.message, 'error');
          btn.disabled = false;
          btn.textContent = '인증번호 발송';
        }
      } catch (err) {
        showMsg(1, '네트워크 오류가 발생했습니다.', 'error');
        btn.disabled = false;
        btn.textContent = '인증번호 발송';
      }
    }

    async function step1Resend() {
      try {
        const res = await fetch('/management/auth/forgot-password/send-code', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ target, target_type: targetType })
        });
        const data = await res.json();
        if (data.success) {
          showMsg(2, '인증번호가 재발송되었습니다.', 'success');
          startTimer(300);
        } else {
          showMsg(2, data.message, 'error');
        }
      } catch (err) {
        showMsg(2, '네트워크 오류가 발생했습니다.', 'error');
      }
    }

    async function step2Verify() {
      const code = document.getElementById('codeInput').value.trim();
      if (!code || code.length !== 6) {
        showMsg(2, '6자리 인증번호를 입력해주세요.', 'error');
        return;
      }

      try {
        const res = await fetch('/management/auth/forgot-password/verify-code', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ target, target_type: targetType, code })
        });
        const data = await res.json();

        if (data.success) {
          clearInterval(timerInterval);
          resetToken = data.reset_token;
          showStep(3);
          document.getElementById('newPassword').focus();
        } else {
          showMsg(2, data.message, 'error');
        }
      } catch (err) {
        showMsg(2, '네트워크 오류가 발생했습니다.', 'error');
      }
    }

    async function step3Reset() {
      const pw = document.getElementById('newPassword').value;
      const pwc = document.getElementById('newPasswordConfirm').value;

      if (!pw || pw.length < 4) {
        showMsg(3, '비밀번호는 4자 이상이어야 합니다.', 'error');
        return;
      }
      if (pw !== pwc) {
        showMsg(3, '비밀번호가 일치하지 않습니다.', 'error');
        return;
      }

      try {
        const res = await fetch('/management/auth/forgot-password/reset', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            target,
            target_type: targetType,
            reset_token: resetToken,
            new_password: pw,
            new_password_confirm: pwc
          })
        });
        const data = await res.json();

        if (data.success) {
          showStep('done');
        } else {
          showMsg(3, data.message, 'error');
        }
      } catch (err) {
        showMsg(3, '네트워크 오류가 발생했습니다.', 'error');
      }
    }

    function startTimer(seconds) {
      clearInterval(timerInterval);
      timerSeconds = seconds;
      updateTimer();
      timerInterval = setInterval(() => {
        timerSeconds--;
        if (timerSeconds <= 0) {
          clearInterval(timerInterval);
          document.getElementById('timer').textContent = '인증번호가 만료되었습니다. 재발송해주세요.';
          return;
        }
        updateTimer();
      }, 1000);
    }

    function updateTimer() {
      const min = Math.floor(timerSeconds / 60);
      const sec = timerSeconds % 60;
      document.getElementById('timer').textContent = `남은 시간: ${min}:${String(sec).padStart(2, '0')}`;
    }
  </script>
</body>
</html>
