      <p class="lp-section-desc">케빈아카데미를 경험한 학생과 학부모의 이야기</p>
    </div>
    <div class="lp-reviews-grid">
      <!-- Review 1 -->
      <div class="lp-review-card">
        <div class="lp-review-stars">
