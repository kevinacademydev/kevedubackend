<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>학생 대시보드 - 케빈아카데미</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="student-layout">
    <!-- Sidebar -->
    <aside class="student-sidebar" id="studentSidebar">
      <div class="sidebar-header">
        <a href="/student" class="sidebar-logo">
          <img src="/images/logo-horizontal-inverted.png" alt="Kevin Academy">
        </a>
        <button class="sidebar-close" id="sidebarClose">&times;</button>
      </div>

      <nav class="sidebar-nav">
        <div class="sidebar-section">
          <button class="sidebar-nav-item sidebar-toggle active" id="classesToggle">
            <span class="sidebar-icon">&#128218;</span>
            <span>내 수업</span>
            <span class="sidebar-arrow" id="classesArrow">&#9660;</span>
          </button>
          <ul class="sidebar-submenu open" id="classesSubmenu">
            <% if (myClasses.length === 0) { %>
              <li class="sidebar-submenu-empty">등록된 수업 없음</li>
            <% } else { %>
              <% myClasses.forEach(cls => { %>
                <li>
                  <a href="/student/class/<%= cls.id %>" class="sidebar-submenu-item">
                    <%= cls.name %>
                  </a>
                </li>
              <% }) %>
            <% } %>
          </ul>
        </div>

        <div class="sidebar-section">
          <a href="#" class="sidebar-nav-item" onclick="alert('준비 중인 기능입니다.'); return false;">
            <span class="sidebar-icon">&#128100;</span>
            <span>학생 프로필 관리</span>
          </a>
        </div>
      </nav>

      <div class="sidebar-divider"></div>

      <div class="sidebar-section">
        <div class="sidebar-section-title">외부 링크</div>
        <a href="https://blog.naver.com/kevedu" target="_blank" rel="noopener" class="sidebar-nav-item sidebar-link">
          <span class="sidebar-icon">&#128221;</span>
          <span>Kevin Academy Blog</span>
          <span class="sidebar-external">&#8599;</span>
        </a>
        <a href="https://pf.kakao.com/_PuTpxb/chat" target="_blank" rel="noopener" class="sidebar-nav-item sidebar-link">
          <span class="sidebar-icon">&#128172;</span>
          <span>카카오톡 상담</span>
          <span class="sidebar-external">&#8599;</span>
        </a>
        <a href="https://www.desmos.com/calculator" target="_blank" rel="noopener" class="sidebar-nav-item sidebar-link">
          <span class="sidebar-icon">&#128202;</span>
          <span>Desmos 계산기</span>
          <span class="sidebar-external">&#8599;</span>
        </a>
      </div>

      <div class="sidebar-footer">
        <div class="sidebar-user">
          <div class="sidebar-user-avatar"><%= user.name.charAt(0) %></div>
          <div class="sidebar-user-info">
            <div class="sidebar-user-name"><%= user.name %></div>
            <div class="sidebar-user-role">학생</div>
          </div>
        </div>
        <a href="/auth/logout" class="sidebar-logout" title="로그아웃">&#9109; 로그아웃</a>
      </div>
    </aside>

    <!-- Sidebar overlay for mobile -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- Main content -->
    <main class="student-main">
      <div class="student-topbar">
        <button class="hamburger-btn" id="hamburgerBtn">&#9776;</button>
        <h2 class="topbar-title">내 수업</h2>
      </div>

      <div class="student-content" id="studentDashboard">
        <% if (myClasses.length === 0) { %>
          <div class="card">
            <div class="card-body">
              <p class="empty-message">등록된 수업이 없습니다. 관리자에게 문의하세요.</p>
            </div>
          </div>
        <% } else { %>
          <div class="class-grid">
            <% myClasses.forEach(cls => { %>
              <a href="/student/class/<%= cls.id %>" class="class-card">
                <div class="class-card-info">
                  <strong><%= cls.name %></strong>
                  <span class="badge"><%= cls.type === 'regular' ? '정규' : cls.type === 'team' ? '그룹' : '개인' %></span>
                  <% if (cls.new_graded_count > 0) { %>
                    <span class="badge badge-new">새 채점 <%= cls.new_graded_count %></span>
                  <% } %>
                </div>
                <div class="class-card-meta">
                  <span>과제 <%= cls.submission_count %>건</span>
                  <span>| 채점 <%= cls.graded_count %>건</span>
                </div>
              </a>
            <% }) %>
          </div>
        <% } %>

        <!-- 피드백 -->
        <% if (feedbacks.length > 0) { %>
        <div class="card" style="margin-top:1.5rem;">
          <div class="card-header"><h3>최근 피드백</h3></div>
          <div class="card-body">
            <% feedbacks.forEach(fb => { %>
              <div class="file-item" style="flex-direction:column;align-items:flex-start;gap:0.25rem;">
                <span class="file-date"><strong><%= fb.author_name %></strong> | <%= fb.created_at %></span>
                <p style="font-size:0.9rem;white-space:pre-wrap;"><%= fb.content %></p>
              </div>
            <% }) %>
          </div>
        </div>
        <% } %>
      </div>
    </main>
  </div>

  <script src="/js/app.js"></script>
</body>
</html>
