<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>학생 목록 - 케빈아카데미</title>
  <link rel="icon" type="image/png" href="/images/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="student-layout">
    <%- include('partials/admin-sidebar', { activePage: 'students-list' }) %>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <main class="student-main">
      <div class="student-topbar">
        <button class="hamburger-btn" id="hamburgerBtn">&#9776;</button>
        <h2 class="topbar-title">학생 목록 (<%= students.length %>명)</h2>
      </div>

      <div class="student-content">
        <div class="card">
          <div class="card-header">
            <h3>전체 학생</h3>
            <input type="text" id="studentSearch" placeholder="이름, 아이디, 학교로 검색..." style="padding:0.4rem 0.75rem;border:1.5px solid var(--gray-300);border-radius:var(--radius);font-size:0.85rem;width:250px;">
          </div>
          <div class="card-body">
            <% if (students.length === 0) { %>
              <p class="empty-message">등록된 학생이 없습니다.</p>
            <% } else { %>
              <table class="table" id="studentsTable">
                <thead>
                  <tr>
                    <th>아이디</th>
                    <th>이름</th>
                    <th>영문이름</th>
                    <th>성별</th>
                    <th>학년</th>
                    <th>학교</th>
                    <th></th>
                  </tr>
                </thead>
                <tbody>
                  <% students.forEach(s => { %>
                    <tr>
                      <td><%= s.username %></td>
                      <td><%= s.name %></td>
                      <td><%= s.name_en || '-' %></td>
                      <td><%= s.gender || '-' %></td>
                      <td><%= s.grade || '-' %></td>
                      <td><%= s.school || '-' %></td>
                      <td><a href="<%= sectionPath %>/student/<%= s.id %>" class="btn btn-sm btn-outline">관리</a></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            <% } %>
          </div>
        </div>
      </div>
    </main>
  </div>

  <script>
    // 학생 검색 필터
    const searchInput = document.getElementById('studentSearch');
    if (searchInput) {
      searchInput.addEventListener('input', function() {
        const q = this.value.toLowerCase();
        document.querySelectorAll('#studentsTable tbody tr').forEach(row => {
          const text = row.textContent.toLowerCase();
          row.style.display = text.includes(q) ? '' : 'none';
        });
      });
    }
  </script>
  <script>window.__SEC='<%= sectionPath %>';window.__BASE='<%= basePath %>'</script>
  <script src="/js/app.js"></script>
</body>
</html>
