<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>관리자 대시보드 - 찬우 수학학원</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="nav-brand">찬우 수학학원</div>
    <div class="nav-info">
      <span class="nav-user"><%= user.name %> (관리자)</span>
      <a href="/auth/logout" class="btn btn-sm btn-outline">로그아웃</a>
    </div>
  </nav>

  <main class="container">
    <h2 class="page-title">관리자 대시보드</h2>

    <div class="dashboard-grid">
      <!-- 채점 파일 업로드 영역 -->
      <section class="card">
        <div class="card-header">
          <h3>채점 파일 업로드</h3>
          <span class="badge">최대 30개</span>
        </div>
        <div class="card-body">
          <div class="upload-info">
            <p>파일명 형식: <code>chaejumXXXX.pdf</code></p>
            <p>예: chaejum0001.pdf → student0001에 자동 매칭</p>
          </div>
          <div class="dropzone" id="adminDropzone" data-url="/admin/upload" data-max="30">
            <div class="dropzone-content">
              <div class="dropzone-icon">+</div>
              <p>채점 파일을 드래그하여 놓거나 클릭하세요</p>
              <p class="dropzone-hint">PDF, JPG, PNG (최대 30개)</p>
            </div>
            <input type="file" id="adminFileInput" multiple accept=".pdf,.jpg,.jpeg,.png" style="display:none">
          </div>
          <div id="adminUploadProgress" class="upload-progress" style="display:none">
            <div class="progress-bar"><div class="progress-fill"></div></div>
            <span class="progress-text">업로드 중...</span>
          </div>
          <div id="adminUploadResult" class="upload-result"></div>
        </div>
      </section>

      <!-- 학생 목록 -->
      <section class="card">
        <div class="card-header">
          <h3>학생 목록</h3>
          <span class="badge"><%= students.length %>명</span>
        </div>
        <div class="card-body">
          <div class="student-list-scroll">
            <table class="table">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>이름</th>
                  <th>학교</th>
                  <th>과목</th>
                </tr>
              </thead>
              <tbody>
                <% students.forEach(s => { %>
                  <tr>
                    <td><a href="/admin/student/<%= s.id %>" class="student-link"><%= s.student_id %></a></td>
                    <td><a href="/admin/student/<%= s.id %>" class="student-link"><%= s.name %></a></td>
                    <td><%= s.school || '-' %></td>
                    <td><%= s.classes || '-' %></td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      </section>
    </div>

    <!-- 추가 첨삭 요청 관리 -->
    <section class="card" style="margin-top: 1.5rem;">
      <div class="card-header">
        <h3>추가 첨삭 요청</h3>
        <% if (extraRequests.filter(r => r.status === 'payment_sent').length > 0) { %>
          <span class="badge badge-new"><%= extraRequests.filter(r => r.status === 'payment_sent').length %>건 입금확인 필요</span>
        <% } %>
      </div>
      <div class="card-body">
        <% if (extraRequests.length === 0) { %>
          <p class="empty-message">추가 첨삭 요청이 없습니다.</p>
        <% } else { %>
          <table class="table">
            <thead>
              <tr>
                <th>학생 ID</th>
                <th>이름</th>
                <th>페이지</th>
                <th>금액</th>
                <th>상태</th>
                <th>요청일시</th>
                <th>파일</th>
                <th>관리</th>
              </tr>
            </thead>
            <tbody>
              <% extraRequests.forEach(er => { %>
                <tr>
                  <td><%= er.student_id %></td>
                  <td><%= er.name %></td>
                  <td><%= er.page_count %>장</td>
                  <td><%= er.total_amount.toLocaleString ? er.total_amount.toLocaleString() : er.total_amount %>원</td>
                  <td>
                    <% if (er.status === 'payment_pending') { %>
                      <span class="status-badge status-pending">결제 대기</span>
                    <% } else if (er.status === 'payment_sent') { %>
                      <span class="status-badge status-sent">입금 확인중</span>
                    <% } else if (er.status === 'approved') { %>
                      <span class="status-badge status-approved">승인됨</span>
                    <% } else if (er.status === 'rejected') { %>
                      <span class="status-badge status-rejected">거절됨</span>
                    <% } else if (er.status === 'completed') { %>
                      <span class="status-badge status-completed">완료</span>
                    <% } %>
                  </td>
                  <td><%= er.requested_at %></td>
                  <td><%= er.file_names || '-' %></td>
                  <td class="action-buttons">
                    <% if (er.status === 'payment_sent' || er.status === 'payment_pending') { %>
                      <button class="btn btn-sm btn-success btn-approve" data-id="<%= er.id %>">승인</button>
                      <button class="btn btn-sm btn-danger btn-reject" data-id="<%= er.id %>">거절</button>
                    <% } else if (er.status === 'approved') { %>
                      <button class="btn btn-sm btn-primary btn-complete" data-id="<%= er.id %>">완료</button>
                    <% } else { %>
                      -
                    <% } %>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } %>
      </div>
    </section>

    <!-- 거절 사유 모달 -->
    <div class="modal-overlay" id="rejectModal" style="display:none">
      <div class="modal">
        <div class="modal-header">
          <h3>거절 사유 입력</h3>
          <button class="modal-close" id="rejectModalClose">&times;</button>
        </div>
        <div class="modal-body">
          <div class="form-group">
            <label for="rejectNote">거절 사유 (선택)</label>
            <input type="text" id="rejectNote" placeholder="예: 입금 확인 불가">
          </div>
        </div>
        <div class="modal-footer">
          <button class="btn btn-outline" id="rejectModalCancel">취소</button>
          <button class="btn btn-danger" id="rejectModalConfirm">거절</button>
        </div>
      </div>
    </div>

    <!-- 최근 과제 제출 -->
    <section class="card" style="margin-top: 1.5rem;">
      <div class="card-header">
        <h3>최근 과제 제출</h3>
      </div>
      <div class="card-body">
        <% if (submissions.length === 0) { %>
          <p class="empty-message">아직 제출된 과제가 없습니다.</p>
        <% } else { %>
          <table class="table">
            <thead>
              <tr>
                <th>학생 ID</th>
                <th>이름</th>
                <th>파일명</th>
                <th>제출일시</th>
                <th>다운로드</th>
              </tr>
            </thead>
            <tbody>
              <% submissions.forEach(sub => { %>
                <tr>
                  <td><%= sub.student_id %></td>
                  <td><%= sub.name %></td>
                  <td><%= sub.file_name %></td>
                  <td><%= sub.submitted_at %></td>
                  <td><a href="/admin/file/<%= sub.id %>" class="btn btn-sm btn-primary">다운로드</a></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } %>
      </div>
    </section>

    <!-- 최근 채점 업로드 -->
    <section class="card" style="margin-top: 1.5rem;">
      <div class="card-header">
        <h3>최근 채점 업로드</h3>
      </div>
      <div class="card-body">
        <% if (gradedFiles.length === 0) { %>
          <p class="empty-message">아직 업로드된 채점 파일이 없습니다.</p>
        <% } else { %>
          <table class="table">
            <thead>
              <tr>
                <th>학생 ID</th>
                <th>이름</th>
                <th>파일명</th>
                <th>업로드일시</th>
                <th>상태</th>
              </tr>
            </thead>
            <tbody>
              <% gradedFiles.forEach(g => { %>
                <tr>
                  <td><%= g.student_id %></td>
                  <td><%= g.name %></td>
                  <td><%= g.file_name %></td>
                  <td><%= g.uploaded_at %></td>
                  <td><%= g.is_new ? '미확인' : '확인완료' %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } %>
      </div>
    </section>
  </main>

  <script src="/js/app.js"></script>
</body>
</html>
