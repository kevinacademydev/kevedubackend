<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>관리자 대시보드 - 케빈아카데미</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="student-layout">
    <%- include('partials/admin-sidebar', { activePage: 'dashboard' }) %>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <main class="student-main">
      <div class="student-topbar">
        <button class="hamburger-btn" id="hamburgerBtn">&#9776;</button>
        <h2 class="topbar-title">대시보드</h2>
      </div>

      <div class="student-content" id="adminDashboard"
           data-user-role="<%= userRole %>"
           data-user-id="<%= userId %>">

        <!-- 수업 일정 Overview -->
        <div class="card" style="margin-bottom:1.5rem;" id="dashboardScheduleCard">
          <div class="card-header">
            <h3>수업 일정</h3>
            <div class="schedule-tab-nav">
              <button class="btn btn-sm btn-primary schedule-tab active" data-tab="day">일별</button>
              <button class="btn btn-sm btn-outline schedule-tab" data-tab="week">주별</button>
              <button class="btn btn-sm btn-outline schedule-tab" data-tab="month">월별</button>
            </div>
          </div>
          <div class="card-body">
            <div id="dashScheduleNav" style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.75rem;">
              <button class="btn btn-sm btn-outline" id="dashNavPrev">&larr;</button>
              <span id="dashNavTitle" style="font-weight:600;font-size:0.9rem;min-width:160px;text-align:center;"></span>
              <button class="btn btn-sm btn-outline" id="dashNavNext">&rarr;</button>
              <button class="btn btn-sm btn-outline" id="dashNavToday" style="margin-left:0.25rem;">오늘</button>
            </div>
            <div id="dashScheduleContent">
              <p class="empty-message">일정을 불러오는 중...</p>
            </div>
            <div id="dashMonthCalendar" style="display:none;">
              <div class="calendar-weekdays">
                <div class="calendar-weekday">월</div>
                <div class="calendar-weekday">화</div>
                <div class="calendar-weekday">수</div>
                <div class="calendar-weekday">목</div>
                <div class="calendar-weekday">금</div>
                <div class="calendar-weekday sat">토</div>
                <div class="calendar-weekday sun">일</div>
              </div>
              <div class="calendar-grid" id="dashCalendarGrid"></div>
            </div>
          </div>
        </div>

        <div class="dashboard-grid">
          <!-- Left: 수업 목록 -->
          <div>
            <div class="card">
              <div class="card-header">
                <h3>수업 목록</h3>
                <% if (userRole === 'admin' || userRole === 'subadmin') { %>
                  <button class="btn btn-sm btn-primary" id="btnCreateClass">+ 수업 생성</button>
                <% } %>
              </div>
              <div class="card-body">
                <% if (classes.length === 0) { %>
                  <p class="empty-message">등록된 수업이 없습니다.</p>
                <% } else { %>
                  <div class="class-list">
                    <% classes.forEach(cls => { %>
                      <a href="<%= sectionPath %>/class/<%= cls.id %>" class="class-card <%= cls.status === 'inactive' ? 'class-inactive' : '' %>">
                        <div class="class-card-info">
                          <strong><%= cls.name %></strong>
                          <span class="badge"><%= cls.type === 'regular' ? '정규' : cls.type === 'team' ? '그룹' : '개인' %></span>
                          <% if (cls.status === 'inactive') { %><span class="badge">비활성</span><% } %>
                        </div>
                        <div class="class-card-meta">
                          <span>학생 <%= cls.student_count %>명</span>
                          <% if (cls.teacher_names) { %><span>| <%= cls.teacher_names %></span><% } %>
                        </div>
                      </a>
                    <% }) %>
                  </div>
                <% } %>
              </div>
            </div>

            <% if (userRole === 'admin' || userRole === 'subadmin') { %>
            <div class="card" style="margin-top: 1.5rem;">
              <div class="card-header">
                <h3>강사 관리</h3>
                <div style="display:flex;gap:0.5rem;align-items:center;">
                  <a href="<%= sectionPath %>/teachers" class="btn btn-sm btn-outline">더보기</a>
                  <% if (userRole === 'admin') { %>
                    <button class="btn btn-sm btn-primary" id="btnCreateTeacher">+ 강사 생성</button>
                  <% } %>
                </div>
              </div>
              <div class="card-body">
                <% if (teachers.length === 0) { %>
                  <p class="empty-message">등록된 강사가 없습니다.</p>
                <% } else { %>
                  <table class="table">
                    <thead>
                      <tr><th>아이디</th><th>이름</th><th>담당 수업</th><% if (userRole === 'admin') { %><th></th><% } %></tr>
                    </thead>
                    <tbody>
                      <% teachers.forEach(t => { %>
                        <tr>
                          <td><%= t.username %></td>
                          <td><%= t.name %></td>
                          <td><%= t.class_count %>개</td>
                          <% if (userRole === 'admin') { %>
                          <td>
                            <button class="btn btn-sm btn-danger btn-delete-teacher" data-id="<%= t.id %>">삭제</button>
                          </td>
                          <% } %>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                <% } %>
              </div>
            </div>
            <% } %>

            <div class="card" style="margin-top: 1.5rem;">
              <div class="card-header">
                <h3>통계</h3>
                <a href="<%= sectionPath %>/stats" class="btn btn-sm btn-outline">더보기</a>
              </div>
              <div class="card-body">
                <p><%= userRole === 'admin' || userRole === 'subadmin' ? '전체' : '담당' %> 수업: <strong><%= classes.length %></strong>개</p>
                <p>학생 수: <strong><%= uniqueStudentCount %></strong>명</p>
                <p>구좌 수: <strong><%= enrollmentCount %></strong>건</p>
                <% if (userRole === 'admin' || userRole === 'subadmin') { %>
                  <p>전체 강사: <strong><%= teachers.length %></strong>명</p>
                <% } %>
              </div>
            </div>
          </div>

          <!-- Right: 최근 활동 -->
          <div>
            <div class="card">
              <div class="card-header">
                <h3>최근 과제 제출</h3>
                <a href="<%= sectionPath %>/submissions" class="btn btn-sm btn-outline">더보기</a>
              </div>
              <div class="card-body">
                <% if (submissions.length === 0) { %>
                  <p class="empty-message">최근 과제 제출이 없습니다.</p>
                <% } else { %>
                  <div class="file-list">
                    <% submissions.forEach(s => { %>
                      <div class="file-item">
                        <div class="file-info">
                          <span class="file-name">
                            <a href="<%= sectionPath %>/student/<%= s.student_id %>" class="student-link"><%= s.username %></a> - <%= s.file_name %>
                          </span>
                          <span class="file-date"><%= s.class_name %> | <%= s.submitted_at %></span>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                <% } %>
              </div>
            </div>

            <div class="card" style="margin-top: 1.5rem;">
              <div class="card-header">
                <h3>최근 채점 업로드</h3>
                <a href="<%= sectionPath %>/graded" class="btn btn-sm btn-outline">더보기</a>
              </div>
              <div class="card-body">
                <% if (gradedFiles.length === 0) { %>
                  <p class="empty-message">최근 채점 파일이 없습니다.</p>
                <% } else { %>
                  <div class="file-list">
                    <% gradedFiles.forEach(g => { %>
                      <div class="file-item">
                        <div class="file-info">
                          <span class="file-name">
                            <a href="<%= sectionPath %>/student/<%= g.student_id %>" class="student-link"><%= g.username %></a> - <%= g.file_name %>
                          </span>
                          <span class="file-date"><%= g.class_name %> | <%= g.uploaded_at %></span>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                <% } %>
              </div>
            </div>
          </div>

          <!-- 파일 관리 (전체 너비) -->
          <div style="grid-column: 1 / -1;">
            <div class="card">
              <div class="card-header">
                <h3>&#128193; 파일 관리</h3>
                <a href="<%= sectionPath %>/files" class="btn btn-sm btn-primary">파일 탐색기 열기</a>
              </div>
              <div class="card-body" id="dashFileSection">
                <p class="empty-message">최근 파일을 불러오는 중...</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- 수업 생성 모달 -->
  <div id="createClassModal" class="modal-overlay" style="display:none;">
    <div class="modal">
      <div class="modal-header">
        <h3>수업 생성</h3>
        <button class="modal-close" onclick="document.getElementById('createClassModal').style.display='none'">&times;</button>
      </div>
      <div class="modal-body">
        <div class="form-group" style="margin-bottom:1rem;">
          <label>수업 이름</label>
          <input type="text" id="newClassName" placeholder="예: 수학 심화반 C">
        </div>
        <div class="form-group">
          <label>유형</label>
          <select id="newClassType">
            <option value="regular">정규</option>
            <option value="team">그룹</option>
            <option value="private">개인</option>
          </select>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline" onclick="document.getElementById('createClassModal').style.display='none'">취소</button>
        <button class="btn btn-primary" id="btnConfirmCreateClass">생성</button>
      </div>
    </div>
  </div>

  <!-- 강사 생성 모달 -->
  <div id="createTeacherModal" class="modal-overlay" style="display:none;">
    <div class="modal">
      <div class="modal-header">
        <h3>강사 계정 생성</h3>
        <button class="modal-close" onclick="document.getElementById('createTeacherModal').style.display='none'">&times;</button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="newTeacherRole" value="teacher">
        <div class="form-group" style="margin-bottom:1rem;">
          <label>아이디</label>
          <input type="text" id="newTeacherId" placeholder="예: teacher4">
        </div>
        <div class="form-group" style="margin-bottom:1rem;">
          <label>이름</label>
          <input type="text" id="newTeacherName" placeholder="예: 최선생">
        </div>
        <div class="form-group">
          <label>비밀번호</label>
          <input type="password" id="newTeacherPw" placeholder="비밀번호">
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline" onclick="document.getElementById('createTeacherModal').style.display='none'">취소</button>
        <button class="btn btn-primary" id="btnConfirmCreateTeacher">생성</button>
      </div>
    </div>
  </div>

  <script>window.__SEC='<%= sectionPath %>';window.__BASE='<%= basePath %>'</script>
  <script src="/js/app.js"></script>
  <script>
    // 대시보드 파일 관리 미니 위젯
    (function() {
      const section = document.getElementById('dashFileSection');
      if (!section) return;

      async function loadRecentFiles() {
        try {
          const res = await fetch(window.__SEC + '/files/list?prefix=uploads/');
          if (!res.ok) throw new Error('Failed');
          const data = await res.json();

          const files = data.files || [];
          if (files.length === 0 && (!data.prefixes || data.prefixes.length === 0)) {
            section.innerHTML = '<p class="empty-message">업로드된 파일이 없습니다. <a href="<%= sectionPath %>/files">파일 탐색기</a>에서 업로드하세요.</p>';
            return;
          }

          // 최근 5개 파일만 표시
          const recent = files.sort((a, b) => new Date(b.updated) - new Date(a.updated)).slice(0, 5);
          const folderCount = (data.prefixes || []).length;

          let html = '<div class="file-list">';
          recent.forEach(f => {
            const icon = f.contentType && f.contentType.startsWith('image/') ? '&#128444;' : '&#128196;';
            const size = formatSize(f.size);
            const date = f.updated ? new Date(f.updated).toLocaleDateString('ko-KR') : '';
            html += '<div class="file-item">';
            html += '  <div class="file-info">';
            html += '    <span class="file-name">' + icon + ' ' + escapeHtml(f.name) + '</span>';
            html += '    <span class="file-date">' + size + ' | ' + date + '</span>';
            html += '  </div>';
            html += '</div>';
          });
          html += '</div>';

          if (files.length > 5 || folderCount > 0) {
            html += '<p style="margin-top:0.75rem;font-size:0.85rem;color:#64748b;">';
            html += '총 ' + files.length + '개 파일';
            if (folderCount > 0) html += ', ' + folderCount + '개 폴더';
            html += ' — <a href="<%= sectionPath %>/files">전체 보기</a></p>';
          }

          section.innerHTML = html;
        } catch (err) {
          section.innerHTML = '<p class="empty-message">파일 목록을 불러올 수 없습니다. <a href="<%= sectionPath %>/files">파일 탐색기</a></p>';
        }
      }

      function formatSize(bytes) {
        if (!bytes) return '0 B';
        var units = ['B', 'KB', 'MB', 'GB'], i = 0, s = bytes;
        while (s >= 1024 && i < units.length - 1) { s /= 1024; i++; }
        return s.toFixed(i === 0 ? 0 : 1) + ' ' + units[i];
      }

      function escapeHtml(str) {
        var div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
      }

      loadRecentFiles();
    })();
  </script>
</body>
</html>
