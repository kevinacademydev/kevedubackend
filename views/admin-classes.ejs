<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : '수업 관리' %> - 케빈아카데미</title>
  <link rel="icon" type="image/png" href="/images/favicon.png">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="student-layout">
    <%- include('partials/admin-sidebar', { activePage: typeof activePage !== 'undefined' ? activePage : 'classes' }) %>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <main class="student-main">
      <div class="student-topbar">
        <button class="hamburger-btn" id="hamburgerBtn">&#9776;</button>
        <h2 class="topbar-title"><%= typeof pageTitle !== 'undefined' ? pageTitle : '수업' %></h2>
      </div>

      <div class="student-content" id="adminClassesPage"
           data-user-role="<%= userRole %>">

        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.25rem;">
          <h3 style="margin:0;font-size:1.1rem;"><%= typeof pageTitle !== 'undefined' ? pageTitle : '전체 수업' %> (<%= classes.length %>)</h3>
          <div style="display:flex;gap:0.5rem;align-items:center;">
            <% if (userRole === 'admin' || userRole === 'subadmin') { %>
              <button class="btn btn-outline" id="btnEditMode">편집</button>
              <button class="btn btn-primary" id="btnCreateClass">+ 수업 생성</button>
            <% } %>
          </div>
        </div>

        <% if (userRole === 'admin' || userRole === 'subadmin') { %>
        <div class="bulk-toolbar" id="bulkToolbar" style="display:none;">
          <span class="bulk-toolbar-count" id="bulkCount">0개 선택</span>
          <button class="btn btn-sm" style="background:#3b82f6;color:#fff;" data-bulk-status="active">진행 중으로 이동</button>
          <button class="btn btn-sm" style="background:#f59e0b;color:#fff;" data-bulk-status="upcoming">예정으로 이동</button>
          <button class="btn btn-sm" style="background:#6b7280;color:#fff;" data-bulk-status="inactive">종강으로 이동</button>
          <button class="btn btn-sm btn-outline" id="btnCancelEdit">취소</button>
        </div>
        <% } %>

        <%
          const activeClasses = classes.filter(c => c.status === 'active');
          const upcomingClasses = classes.filter(c => c.status === 'upcoming');
          const inactiveClasses = classes.filter(c => c.status === 'inactive');
          const statusGroups = [
            { key: 'active', label: '진행 중', items: activeClasses, defaultOpen: true },
            { key: 'upcoming', label: '예정', items: upcomingClasses, defaultOpen: true },
            { key: 'inactive', label: '종강', items: inactiveClasses, defaultOpen: false }
          ];
        %>

        <div class="classes-columns">
          <% statusGroups.forEach(group => { %>
            <div class="classes-column">
              <div class="classes-column-header">
                <label class="bulk-checkbox" style="display:none;"><input type="checkbox" class="bulk-select-all" data-status="<%= group.key %>"></label>
                <h3><%= group.label %></h3>
                <span class="badge"><%= group.items.length %></span>
              </div>
              <div class="classes-column-body">
                <% if (group.items.length === 0) { %>
                  <p class="empty-message">수업이 없습니다.</p>
                <% } else { %>
                  <% group.items.forEach(cls => { %>
                    <div class="classes-col-card-wrap" data-class-id="<%= cls.id %>" data-status="<%= group.key %>">
                      <label class="bulk-checkbox" style="display:none;"><input type="checkbox" class="bulk-item-check" value="<%= cls.id %>"></label>
                      <a href="<%= sectionPath %>/class/<%= cls.id %>" class="classes-col-card">
                        <div class="classes-col-card-name" title="<%= cls.name %>">
                          <%= cls.name %>
                        </div>
                        <div class="classes-col-card-meta">
                          <span class="badge"><%= cls.type === 'regular' ? '정규' : cls.type === 'team' ? '그룹' : '개인' %></span>
                          <span>학생 <%= cls.student_count %>명</span>
                        </div>
                        <% if (cls.teacher_names) { %>
                          <div class="classes-col-card-teacher"><%= cls.teacher_names %></div>
                        <% } %>
                      </a>
                    </div>
                  <% }) %>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>

      </div>
    </main>
  </div>

  <!-- 수업 생성 모달 -->
  <div id="createClassModal" class="modal-overlay" style="display:none;">
    <div class="modal">
      <div class="modal-header">
        <h3>수업 생성</h3>
        <button class="modal-close" onclick="document.getElementById('createClassModal').style.display='none'">&times;</button>
      </div>
      <div class="modal-body">
        <div class="form-group" style="margin-bottom:1rem;">
          <label>수업 이름</label>
          <input type="text" id="newClassName" placeholder="예: 수학 심화반 C">
        </div>
        <div class="form-group">
          <label>유형</label>
          <select id="newClassType">
            <option value="regular">정규</option>
            <option value="team">그룹</option>
            <option value="private">개인</option>
          </select>
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline" onclick="document.getElementById('createClassModal').style.display='none'">취소</button>
        <button class="btn btn-primary" id="btnConfirmCreateClass">생성</button>
      </div>
    </div>
  </div>

  <script>window.__SEC='<%= sectionPath %>';window.__BASE='<%= basePath %>'</script>
  <script src="/js/app.js"></script>
</body>
</html>
