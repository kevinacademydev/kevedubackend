<!-- Admin/Teacher Sidebar -->
<aside class="student-sidebar" id="adminSidebar">
  <div class="sidebar-header">
    <a href="<%= sectionPath %>" class="sidebar-logo">
      <img src="/images/logo-horizontal-inverted.png" alt="Kevin Academy">
    </a>
    <button class="sidebar-close" id="sidebarClose">&times;</button>
  </div>

  <nav class="sidebar-nav">
    <div class="sidebar-section">
      <a href="<%= sectionPath %>" class="sidebar-nav-item <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">
        <span class="sidebar-icon">&#127968;</span>
        <span>대시보드</span>
      </a>
    </div>

    <% if (user.role === 'admin' || user.role === 'subadmin') { %>
      <%/* ===== admin/subadmin: "내 수업" 아코디언 + "전체 수업 관리" 링크 ===== */ %>
      <% const myClasses = typeof mySidebarClasses !== 'undefined' ? mySidebarClasses : []; %>
      <% const myActive = myClasses.filter(c => c.status === 'active'); %>
      <% const myUpcoming = myClasses.filter(c => c.status === 'upcoming'); %>
      <% const myInactive = myClasses.filter(c => c.status === 'inactive'); %>

      <div class="sidebar-section">
        <div class="sidebar-nav-item sidebar-toggle-classes <%= typeof activePage !== 'undefined' && activePage === 'my-classes' ? 'active' : '' %>" data-target="myClassesSubmenu">
          <a href="<%= sectionPath %>/my-classes" class="sidebar-classes-link" onclick="event.stopPropagation();">
            <span class="sidebar-icon">&#127891;</span>
            <span>내 수업</span>
          </a>
          <button class="sidebar-arrow-btn" type="button" data-target="myClassesSubmenu">&#9660;</button>
        </div>
        <ul class="sidebar-submenu" id="myClassesSubmenu">
          <% if (myActive.length > 0) { %>
          <li class="sidebar-subgroup">
            <button class="sidebar-subgroup-toggle active" data-target="myActiveClassesSub">
              <span>진행 중 (<%= myActive.length %>)</span>
              <span class="sidebar-arrow">&#9660;</span>
            </button>
            <ul class="sidebar-submenu open" id="myActiveClassesSub">
              <% myActive.forEach(cls => { %>
                <li>
                  <a href="<%= sectionPath %>/class/<%= cls.id %>" class="sidebar-submenu-item <%= typeof activeClassId !== 'undefined' && activeClassId == cls.id ? 'active' : '' %>">
                    <%= cls.name %>
                  </a>
                </li>
              <% }) %>
            </ul>
          </li>
          <% } %>

          <% if (myUpcoming.length > 0) { %>
          <li class="sidebar-subgroup">
            <button class="sidebar-subgroup-toggle" data-target="myUpcomingClassesSub">
              <span>예정 (<%= myUpcoming.length %>)</span>
              <span class="sidebar-arrow">&#9654;</span>
            </button>
            <ul class="sidebar-submenu" id="myUpcomingClassesSub">
              <% myUpcoming.forEach(cls => { %>
                <li>
                  <a href="<%= sectionPath %>/class/<%= cls.id %>" class="sidebar-submenu-item class-upcoming <%= typeof activeClassId !== 'undefined' && activeClassId == cls.id ? 'active' : '' %>">
                    <%= cls.name %>
                  </a>
                </li>
              <% }) %>
            </ul>
          </li>
          <% } %>

          <% if (myInactive.length > 0) { %>
          <li class="sidebar-subgroup">
            <button class="sidebar-subgroup-toggle" data-target="myInactiveClassesSub">
              <span>종강 (<%= myInactive.length %>)</span>
              <span class="sidebar-arrow">&#9654;</span>
            </button>
            <ul class="sidebar-submenu" id="myInactiveClassesSub">
              <% myInactive.forEach(cls => { %>
                <li>
                  <a href="<%= sectionPath %>/class/<%= cls.id %>" class="sidebar-submenu-item class-inactive <%= typeof activeClassId !== 'undefined' && activeClassId == cls.id ? 'active' : '' %>">
                    <%= cls.name %>
                  </a>
                </li>
              <% }) %>
            </ul>
          </li>
          <% } %>

          <% if (myClasses.length === 0) { %>
            <li class="sidebar-submenu-empty">담당 수업 없음</li>
          <% } %>
        </ul>
      </div>

      <div class="sidebar-section">
        <a href="<%= sectionPath %>/classes" class="sidebar-nav-item <%= typeof activePage !== 'undefined' && activePage === 'classes' ? 'active' : '' %>">
          <span class="sidebar-icon">&#128209;</span>
          <span>전체 수업 관리</span>
        </a>
      </div>

    <% } else { %>
      <%/* ===== teacher: 기존 "수업" 아코디언 ===== */ %>
      <% const activeClasses = sidebarClasses.filter(c => c.status === 'active'); %>
      <% const upcomingClasses = sidebarClasses.filter(c => c.status === 'upcoming'); %>
      <% const inactiveClasses = sidebarClasses.filter(c => c.status === 'inactive'); %>

      <div class="sidebar-section">
        <div class="sidebar-nav-item sidebar-toggle-classes <%= typeof activePage !== 'undefined' && activePage === 'classes' ? 'active' : '' %>" data-target="classesSubmenu">
          <a href="<%= sectionPath %>/classes" class="sidebar-classes-link" onclick="event.stopPropagation();">
            <span class="sidebar-icon">&#127891;</span>
            <span>수업</span>
          </a>
          <button class="sidebar-arrow-btn" type="button" data-target="classesSubmenu">&#9660;</button>
        </div>
        <ul class="sidebar-submenu" id="classesSubmenu">
          <% if (activeClasses.length > 0) { %>
          <li class="sidebar-subgroup">
            <button class="sidebar-subgroup-toggle active" data-target="activeClassesSub">
              <span>진행 중 (<%= activeClasses.length %>)</span>
              <span class="sidebar-arrow">&#9660;</span>
            </button>
            <ul class="sidebar-submenu open" id="activeClassesSub">
              <% activeClasses.forEach(cls => { %>
                <li>
                  <a href="<%= sectionPath %>/class/<%= cls.id %>" class="sidebar-submenu-item <%= typeof activeClassId !== 'undefined' && activeClassId == cls.id ? 'active' : '' %>">
                    <%= cls.name %>
                  </a>
                </li>
              <% }) %>
            </ul>
          </li>
          <% } %>

          <% if (upcomingClasses.length > 0) { %>
          <li class="sidebar-subgroup">
            <button class="sidebar-subgroup-toggle" data-target="upcomingClassesSub">
              <span>예정 (<%= upcomingClasses.length %>)</span>
              <span class="sidebar-arrow">&#9654;</span>
            </button>
            <ul class="sidebar-submenu" id="upcomingClassesSub">
              <% upcomingClasses.forEach(cls => { %>
                <li>
                  <a href="<%= sectionPath %>/class/<%= cls.id %>" class="sidebar-submenu-item class-upcoming <%= typeof activeClassId !== 'undefined' && activeClassId == cls.id ? 'active' : '' %>">
                    <%= cls.name %>
                  </a>
                </li>
              <% }) %>
            </ul>
          </li>
          <% } %>

          <% if (inactiveClasses.length > 0) { %>
          <li class="sidebar-subgroup">
            <button class="sidebar-subgroup-toggle" data-target="inactiveClassesSub">
              <span>종강 (<%= inactiveClasses.length %>)</span>
              <span class="sidebar-arrow">&#9654;</span>
            </button>
            <ul class="sidebar-submenu" id="inactiveClassesSub">
              <% inactiveClasses.forEach(cls => { %>
                <li>
                  <a href="<%= sectionPath %>/class/<%= cls.id %>" class="sidebar-submenu-item class-inactive <%= typeof activeClassId !== 'undefined' && activeClassId == cls.id ? 'active' : '' %>">
                    <%= cls.name %>
                  </a>
                </li>
              <% }) %>
            </ul>
          </li>
          <% } %>

          <% if (sidebarClasses.length === 0) { %>
            <li class="sidebar-submenu-empty">등록된 수업 없음</li>
          <% } %>
        </ul>
      </div>
    <% } %>

    <div class="sidebar-section">
      <a href="<%= sectionPath %>/<%= user.username %>/students-list" class="sidebar-nav-item <%= typeof activePage !== 'undefined' && activePage === 'students-list' ? 'active' : '' %>">
        <span class="sidebar-icon sidebar-icon-white">&#128101;</span>
        <span>학생 목록</span>
      </a>
    </div>

    <% if (user.role === 'admin' || user.role === 'subadmin') { %>
    <div class="sidebar-section">
      <a href="<%= sectionPath %>/teachers" class="sidebar-nav-item <%= typeof activePage !== 'undefined' && activePage === 'teachers' ? 'active' : '' %>">
        <span class="sidebar-icon sidebar-icon-white">&#128100;</span>
        <span>강사 관리</span>
      </a>
    </div>
    <% } %>

    <div class="sidebar-section">
      <a href="<%= sectionPath %>/submissions" class="sidebar-nav-item <%= typeof activePage !== 'undefined' && activePage === 'submissions' ? 'active' : '' %>">
        <span class="sidebar-icon">&#128196;</span>
        <span>최근 과제 제출</span>
      </a>
    </div>

    <div class="sidebar-section">
      <a href="<%= sectionPath %>/graded" class="sidebar-nav-item <%= typeof activePage !== 'undefined' && activePage === 'graded' ? 'active' : '' %>">
        <span class="sidebar-icon">&#128221;</span>
        <span>최근 채점 업로드</span>
      </a>
    </div>

    <div class="sidebar-section">
      <a href="<%= sectionPath %>/stats" class="sidebar-nav-item <%= typeof activePage !== 'undefined' && activePage === 'stats' ? 'active' : '' %>">
        <span class="sidebar-icon">&#128200;</span>
        <span>통계</span>
      </a>
    </div>

    <div class="sidebar-section">
      <a href="<%= sectionPath %>/schedule-pages" class="sidebar-nav-item <%= typeof activePage !== 'undefined' && activePage === 'schedule-pages' ? 'active' : '' %>">
        <span class="sidebar-icon">&#128197;</span>
        <span>시간표 만들기</span>
      </a>
    </div>

    <div class="sidebar-section">
      <a href="<%= sectionPath %>/files" class="sidebar-nav-item <%= typeof activePage !== 'undefined' && activePage === 'files' ? 'active' : '' %>">
        <span class="sidebar-icon">&#128193;</span>
        <span>파일 관리</span>
      </a>
    </div>
  </nav>

  <div class="sidebar-divider"></div>

  <div class="sidebar-section">
    <div class="sidebar-section-title">외부 링크</div>
    <a href="https://blog.naver.com/kevedu" target="_blank" rel="noopener" class="sidebar-nav-item sidebar-link">
      <span class="sidebar-icon sidebar-icon-brand"><img src="/images/icon-naver-blog.svg" alt="Naver" class="sidebar-brand-icon"></span>
      <span>Kevin Academy Blog</span>
      <span class="sidebar-external">&#8599;</span>
    </a>
    <a href="https://pf.kakao.com/_PuTpb/chat" target="_blank" rel="noopener" class="sidebar-nav-item sidebar-link">
      <span class="sidebar-icon sidebar-icon-brand"><img src="/images/icon-kakaotalk.svg" alt="KakaoTalk" class="sidebar-brand-icon"></span>
      <span>카카오톡 상담</span>
      <span class="sidebar-external">&#8599;</span>
    </a>
    <a href="https://www.desmos.com/calculator" target="_blank" rel="noopener" class="sidebar-nav-item sidebar-link">
      <span class="sidebar-icon sidebar-icon-brand"><img src="/images/icon-desmos.svg" alt="Desmos" class="sidebar-brand-icon"></span>
      <span>Desmos 계산기</span>
      <span class="sidebar-external">&#8599;</span>
    </a>
  </div>

  <div class="sidebar-footer">
    <div class="sidebar-user">
      <div class="sidebar-user-avatar"><%= user.name.charAt(0) %></div>
      <div class="sidebar-user-info">
        <div class="sidebar-user-name"><%= user.name %></div>
        <div class="sidebar-user-role"><%= user.role === 'admin' ? '원장' : user.role === 'subadmin' ? '부원장' : '강사' %></div>
      </div>
      <a href="<%= sectionPath %>/profile" title="프로필 편집" style="margin-left:auto;color:var(--gray-400);font-size:1.1rem;padding:0.25rem;text-decoration:none;display:flex;align-items:center;">&#9998;</a>
    </div>
    <a href="<%= basePath %>/auth/logout" class="sidebar-logout" title="로그아웃">&#9109; 로그아웃</a>
  </div>
</aside>
